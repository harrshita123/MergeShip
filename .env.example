# MergeShip Environment Variables
# Copy this file to .env and fill in your actual values

# ======================
# Appwrite Configuration
# ======================
# Get these from your Appwrite Console (https://cloud.appwrite.io)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_api_key_here

# ======================
# AI Configuration
# ======================
# Get this from Groq Console (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# ======================
# Application URLs
# ======================
# Your application base URL (change in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ======================
# Database Configuration
# ======================
# MongoDB connection string (optional, for caching)
MONGO_URL=mongodb://localhost:27017
DB_NAME=mergeship

# ======================
# CORS Configuration
# ======================
# Allowed origins for CORS (comma-separated)
# Use * for development, specific domains for production
CORS_ORIGINS=*

# ======================
# Appwrite Database IDs
# ======================
# These should match your Appwrite database setup
DATABASE_ID=69e12a90002821b7a144
COLLECTION_ID=user_stats

# ======================
# Feature Flags
# ======================
# Enable/disable demo mode
ENABLE_DEMO_MODE=true

# ======================
# Optional: External Services
# ======================
# Add any additional API keys here
# SENDGRID_API_KEY=your_sendgrid_key
# STRIPE_SECRET_KEY=your_stripe_key
# SENTRY_DSN=your_sentry_dsn
